{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/your-org/eks-debugger/schemas/output_schema.json",
  "title": "EKS Debugger Output Schema",
  "description": "JSON schema for EKS Comprehensive Debugger output",
  "type": "object",
  "required": ["metadata", "summary", "findings", "errors"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["cluster", "region", "analysis_date"],
      "properties": {
        "cluster": {
          "type": "string",
          "description": "EKS cluster name"
        },
        "region": {
          "type": "string",
          "pattern": "^[a-z]{2}-[a-z]+-[0-9]+$",
          "description": "AWS region (e.g., us-east-1)"
        },
        "analysis_date": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of analysis"
        },
        "date_range": {
          "type": "object",
          "properties": {
            "start": {
              "type": "string",
              "format": "date-time"
            },
            "end": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "namespace": {
          "type": ["string", "null"],
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "description": "Kubernetes namespace filter"
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_issues", "critical", "warning", "info"],
      "properties": {
        "total_issues": {
          "type": "integer",
          "minimum": 0
        },
        "critical": {
          "type": "integer",
          "minimum": 0
        },
        "warning": {
          "type": "integer",
          "minimum": 0
        },
        "info": {
          "type": "integer",
          "minimum": 0
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "findings": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["summary", "details"],
          "properties": {
            "summary": {
              "type": "string"
            },
            "details": {
              "type": "object"
            },
            "severity": {
              "type": "string",
              "enum": ["critical", "warning", "info"]
            },
            "finding_type": {
              "type": "string",
              "enum": ["current_state", "historical"]
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "aws_doc": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      }
    },
    "correlations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["correlation_type", "severity", "root_cause"],
        "properties": {
          "correlation_type": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "warning", "info"]
          },
          "root_cause": {
            "type": "string"
          },
          "root_cause_time": {
            "type": "string",
            "format": "date-time"
          },
          "confidence_tier": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "composite_confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "impact": {
            "type": "string"
          },
          "recommendation": {
            "type": "string"
          },
          "aws_doc": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["time_bucket", "event_count"],
        "properties": {
          "time_bucket": {
            "type": "string"
          },
          "event_count": {
            "type": "integer",
            "minimum": 0
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "warning", "info"]
          }
        }
      }
    },
    "first_issue": {
      "type": ["object", "null"],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "category": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "potential_root_cause": {
          "type": "boolean"
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "category", "priority", "action"],
        "properties": {
          "title": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "action": {
            "type": "string"
          },
          "aws_doc": {
            "type": "string",
            "format": "uri"
          },
          "evidence": {
            "type": "object"
          },
          "diagnostic_steps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "message"],
        "properties": {
          "step": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "performance": {
      "type": "object",
      "properties": {
        "slowest_methods": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "method": {
                "type": "string"
              },
              "total_time_seconds": {
                "type": "number"
              }
            }
          }
        },
        "cache_stats": {
          "type": "object"
        }
      }
    }
  }
}
